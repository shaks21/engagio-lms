generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum EventType {
  MIC
  CHAT
  BLUR
  FOCUS
  JOIN
  LEAVE
  MOUSE_TRACK
  KEYSTROKE
  SCREEN_SHARE
}

model Tenant {
  id                    String             @id @default(uuid())
  name                  String
  users                 User[]
  courses               Course[]
  enrollments           Enrollment[]
  sessions              Session[]
  events                EngagementEvent[]
  engagementSnapshots   EngagementSnapshot[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model User {
  id           String       @id @default(uuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  email        String
  password     String
  role         Role         @default(STUDENT)
  courses      Course[]     @relation("InstructorCourses")
  enrollments  Enrollment[]
  sessions     Session[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Course {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  title         String
  description   String?
  instructorId  String
  instructor    User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  enrollments   Enrollment[]
  sessions      Session[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId])
  @@index([instructorId])
}

model Enrollment {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  courseId  String
  status    String   @default("active")
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, userId, courseId])
  @@index([tenantId])
}

model Session {
  id            String            @id @default(uuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  courseId      String
  course        Course            @relation(fields: [courseId], references: [id])
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  classroomCode String            @unique
  startedAt     DateTime          @default(now())
  endedAt       DateTime?
  dwellTime     Int               @default(0)
  events        EngagementEvent[]

  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
}

model EngagementEvent {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id])
  type      EventType
  payload   Json
  timestamp DateTime  @default(now())

  @@index([tenantId])
  @@index([sessionId])
  @@index([tenantId, sessionId])
  @@index([timestamp])
}

model EngagementSnapshot {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sessionId String
  userId    String
  score     Int
  timestamp DateTime @default(now())

  @@index([tenantId])
  @@index([sessionId])
  @@index([userId])
  @@index([tenantId, sessionId, timestamp])
  @@index([userId, sessionId])
}
